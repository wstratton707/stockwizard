# Optional: Anthropic API key (not needed if using Claude subscription)
ANTHROPIC_API_KEY=sk-ant-xxx

# Optional: FMP API key (for /economic-calendar-fetcher in chat)
# FMP_API_KEY=your_fmp_key_here

# Claude model (default: claude-sonnet-4-6)
CLAUDE_MODEL=claude-sonnet-4-6

# UI locale: en or ja (default: en)
APP_LOCALE=en

# Knowledge search settings (defaults: 8 / 12000)
KNOWLEDGE_MAX_HITS=12
CONTEXT_MAX_CHARS=16000
